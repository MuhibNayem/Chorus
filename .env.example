# FastAPI Backend for Kimi RAG Chatbot

# App
APP_NAME=Kimi RAG Chatbot
DEBUG=true
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/kimirag
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# MinIO Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents

# NVIDIA AI Endpoint
NVIDIA_API_KEY=your-nvidia-api-key-here

# MiniMax Direct API
MINIMAX_API_KEY=your-minimax-api-key-here

# GLM/Zhipu provider
GLM_API_KEY=
ZAI_API_KEY=

# Search providers (priority: Serper -> Google CSE -> Ollama)
SERPER_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
OLLAMA_API_KEY=

# Optional tools
WEATHER_API_KEY=

# JWT Authentication
JWT_SECRET=your-secret-key-here
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
