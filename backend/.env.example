# DeepSeek Backend Environment Variables
#
# For local non-Docker development, keep localhost values.
# For Docker Compose, copy or adapt from `backend/.env.docker`.

# LLM Providers
MINIMAX_API_KEY=your_api_key_here

# Database & Cache
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/deepseek
REDIS_URL=redis://localhost:6379

# MinIO Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=deepseek-projects
MINIO_SECURE=false

# Ollama / Local Embeddings
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
RAG_EMBEDDING_DIMENSION=1536

# Web Search Tools (Optional)
SERPER_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Paths
WORKSPACE_BASE=/tmp/deepseek/workspaces
CHECKPOINT_BASE=/tmp/deepseek/checkpoints

# Advanced Swarm Configuration
LOG_LEVEL=INFO
BACKEND_PORT=8000
# SWARM_RECURSION_LIMIT=5000
# WORKSPACE_MAX_AGE_HOURS=24
